#!/usr/bin/env python3
"""qremind - Desktop reminder app with configurable periodic checking."""

import os
import sys
import tty
import termios
import json
import time
import signal
import subprocess
import argparse
import calendar
from datetime import datetime, timedelta
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "qreminder"
CONFIG_FILE = CONFIG_DIR / "config.json"
PID_FILE = CONFIG_DIR / "daemon.pid"

DEFAULT_CONFIG = {
    "data_file": str(Path.home() / ".config/qReminder/reminders.dat"),
    "hidden_file": str(Path.home() / ".config/qReminder/hidden.txt"),
    "snooze_file": str(Path.home() / ".config/qReminder/snoozed.json"),
    "check_interval_minutes": 60,
    "notification": "zenity",  # "zenity" or "notify-send"
    "snooze_intervals": "30m,1h,2h,3h,6h,12h,24h",
}


# ── Config ────────────────────────────────────────────────────────────────────

def load_config():
    cfg = DEFAULT_CONFIG.copy()
    if CONFIG_FILE.exists():
        try:
            cfg.update(json.loads(CONFIG_FILE.read_text()))
        except (json.JSONDecodeError, OSError) as e:
            print(f"Warning: could not read config: {e}", file=sys.stderr)
    return cfg


def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2) + "\n")


# ── Data helpers ──────────────────────────────────────────────────────────────

def load_reminders(data_file):
    path = Path(data_file)
    if not path.exists():
        return []
    reminders = []
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split(";", 3)
        if len(parts) == 4:
            reminders.append(parts)
    return reminders


def save_reminders(data_file, reminders):
    content = "\n".join(";".join(r) for r in reminders)
    Path(data_file).write_text(content + "\n" if content else "")


def load_hidden(hidden_file):
    path = Path(hidden_file)
    if not path.exists():
        return set()
    return {line.strip() for line in path.read_text().splitlines() if line.strip()}


def save_hidden(hidden_file, hidden):
    Path(hidden_file).parent.mkdir(parents=True, exist_ok=True)
    sorted_ids = sorted(hidden, key=lambda x: int(x) if x.isdigit() else 0)
    content = "\n".join(sorted_ids)
    Path(hidden_file).write_text(content + "\n" if content else "")


def load_snoozed(snooze_file):
    path = Path(snooze_file)
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except (json.JSONDecodeError, OSError):
        return {}


def save_snoozed(snooze_file, snoozed):
    Path(snooze_file).parent.mkdir(parents=True, exist_ok=True)
    Path(snooze_file).write_text(json.dumps(snoozed, indent=2) + "\n")


def next_refno(reminders):
    if not reminders:
        return "1"
    return str(max(int(r[0]) for r in reminders) + 1)


def format_dt(datetime_str):
    return datetime.strptime(datetime_str, "%Y%m%d%H%M").strftime("%b-%d-%Y %H:%M")


def _parse_snooze_intervals(interval_str):
    """Parse '30m,1h,2h' into [(label, minutes), ...] tuples."""
    result = []
    for part in interval_str.split(","):
        part = part.strip()
        try:
            if part.endswith("m"):
                mins = int(part[:-1])
                label = f"{mins} minute" + ("s" if mins != 1 else "")
                result.append((label, mins))
            elif part.endswith("h"):
                hrs = int(part[:-1])
                label = f"{hrs} hour" + ("s" if hrs != 1 else "")
                result.append((label, hrs * 60))
        except ValueError:
            pass
    return result


# ── Notification ──────────────────────────────────────────────────────────────

def _zenity_reminder(refno, text):
    """Show a single reminder in zenity. Returns 'hide', 'snooze', 'delete', or 'dismiss'."""
    result = subprocess.run(
        [
            "zenity", "--question",
            "--title", f"Reminder Due (#{refno})",
            "--text", text,
            "--width=500",
            "--ok-label", "Hide",
            "--cancel-label", "Dismiss",
            "--extra-button", "Snooze",
            "--extra-button", "Delete",
        ],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        return "hide"
    label = result.stdout.strip()
    if label == "Snooze":
        return "snooze"
    if label == "Delete":
        return "delete"
    return "dismiss"


def _zenity_snooze_picker(intervals):
    """Show a snooze duration list. Returns minutes chosen, or None on cancel."""
    height = min(100 + len(intervals) * 35, 500)
    result = subprocess.run(
        [
            "zenity", "--list",
            "--title", "Snooze Reminder",
            "--text", "Snooze for how long?",
            "--column", "Duration",
            "--hide-header",
            "--width=250", f"--height={height}",
        ] + [label for label, _ in intervals],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return None
    label = result.stdout.strip()
    return next((mins for lbl, mins in intervals if lbl == label), None)


# ── Input helpers ─────────────────────────────────────────────────────────────

def _readline_or_cancel(prompt):
    """Read a line of input. Returns the string, or None if ESC is pressed."""
    sys.stdout.write(prompt)
    sys.stdout.flush()
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    buf = []
    try:
        tty.setraw(fd)
        while True:
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return None
            elif ch in ("\r", "\n"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return "".join(buf)
            elif ch in ("\x7f", "\x08"):  # backspace / delete
                if buf:
                    buf.pop()
                    sys.stdout.write("\x08 \x08")
                    sys.stdout.flush()
            elif ch == "\x03":  # Ctrl-C
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                raise KeyboardInterrupt
            elif ch >= " ":
                buf.append(ch)
                sys.stdout.write(ch)
                sys.stdout.flush()
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def _pick_from_list(header, items):
    """Arrow-key selector. Returns selected index or None on ESC."""
    if not items:
        return None

    idx = 0
    n = len(items)

    def draw(first=False):
        if not first:
            sys.stdout.write(f"\x1b[{n + 1}A")
        sys.stdout.write(f"\r{header}\x1b[K\n")
        for i, item in enumerate(items):
            marker = "→" if i == idx else " "
            sys.stdout.write(f"\r  {marker} {item}\x1b[K\n")
        sys.stdout.flush()

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        draw(first=True)
        while True:
            chunk = os.read(fd, 32)
            if chunk == b"\x1b[A":       # up arrow
                idx = max(0, idx - 1)
                draw()
            elif chunk == b"\x1b[B":     # down arrow
                idx = min(n - 1, idx + 1)
                draw()
            elif chunk in (b"\r", b"\n"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return idx
            elif chunk == b"\x1b" or chunk == b"\x03":  # ESC or Ctrl-C
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def _pick_snooze_list(candidates, snoozed):
    """Snooze manager picker.
    Space toggles: unsnoozed → mark for snooze; snoozed → mark for cancel.
    Returns sorted list of toggled indices, or None on ESC."""
    n = len(candidates)
    idx = 0
    toggled = set()

    def status(i):
        refno = candidates[i][0]
        if refno in snoozed:
            if i in toggled:
                return "[ cancel        ]"
            exp = datetime.strptime(snoozed[refno], "%Y%m%d%H%M")
            return f"[≈ {exp.strftime('%b %d %I:%M %p')}]"
        return "[ set snooze    ]" if i in toggled else "[ --            ]"

    def draw(first=False):
        if not first:
            sys.stdout.write(f"\x1b[{n + 2}A")
        sys.stdout.write(f"\rManage snoozes  (Space=toggle  Enter=confirm  ESC=cancel):\x1b[K\n")
        for i, r in enumerate(candidates):
            marker = "→" if i == idx else " "
            topic = r[2][:28]
            sys.stdout.write(f"\r  {marker} #{r[0]:<4} {topic:<28} {status(i)}\x1b[K\n")
        sys.stdout.write(f"\r\x1b[K\n")
        sys.stdout.flush()

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        draw(first=True)
        while True:
            chunk = os.read(fd, 32)
            if chunk == b"\x1b[A":
                idx = max(0, idx - 1)
                draw()
            elif chunk == b"\x1b[B":
                idx = min(n - 1, idx + 1)
                draw()
            elif chunk == b" ":
                toggled.symmetric_difference_update({idx})
                draw()
            elif chunk in (b"\r", b"\n"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return sorted(toggled)
            elif chunk in (b"\x1b", b"\x03"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def _pick_multi_from_list(header, items):
    """Multi-select arrow-key picker. Space toggles, Enter confirms, ESC cancels.
    Returns a sorted list of selected indices, or None on ESC."""
    if not items:
        return None

    idx = 0
    n = len(items)
    selected = set()

    def draw(first=False):
        if not first:
            sys.stdout.write(f"\x1b[{n + 2}A")
        sys.stdout.write(f"\r{header}\x1b[K\n")
        for i, item in enumerate(items):
            marker = "→" if i == idx else " "
            check = "✓" if i in selected else " "
            sys.stdout.write(f"\r  {marker} [{check}] {item}\x1b[K\n")
        sys.stdout.write(f"\r  Space=toggle  Enter=confirm  ESC=cancel\x1b[K\n")
        sys.stdout.flush()

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        draw(first=True)
        while True:
            chunk = os.read(fd, 32)
            if chunk == b"\x1b[A":
                idx = max(0, idx - 1)
                draw()
            elif chunk == b"\x1b[B":
                idx = min(n - 1, idx + 1)
                draw()
            elif chunk == b" ":
                selected.symmetric_difference_update({idx})
                draw()
            elif chunk in (b"\r", b"\n"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return sorted(selected)
            elif chunk in (b"\x1b", b"\x03"):
                sys.stdout.write("\r\n")
                sys.stdout.flush()
                return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def _add_months(dt, months):
    month = dt.month - 1 + months
    year = dt.year + month // 12
    month = month % 12 + 1
    day = min(dt.day, calendar.monthrange(year, month)[1])
    return dt.replace(year=year, month=month, day=day)


def prompt_date(default=None):
    now = datetime.now()

    presets = [
        ("Today",      now),
        ("1 day",      now + timedelta(days=1)),
        ("3 days",     now + timedelta(days=3)),
        ("1 week",     now + timedelta(weeks=1)),
        ("2 weeks",    now + timedelta(weeks=2)),
        ("1 month",    _add_months(now, 1)),
        ("3 months",   _add_months(now, 3)),
        ("6 months",   _add_months(now, 6)),
        ("1 year",     _add_months(now, 12)),
    ]

    print("Date:")
    for i, (label, dt) in enumerate(presets, 1):
        print(f"  {i})  {label:<12} {dt.strftime('%b %d, %Y')}")

    if default:
        prompt = f"  #, or date (YYYYMMDD) [{default}] [esc=cancel]: "
    else:
        prompt = f"  #, or date (YYYYMMDD) [esc=cancel]: "

    while True:
        val = _readline_or_cancel(prompt)
        if val is None:
            return None
        val = val.strip()
        if not val:
            if default:
                return default
            print(f"  Enter a number 1–{len(presets)} or a date (YYYYMMDD).")
            continue
        if val.isdigit() and 1 <= int(val) <= len(presets):
            chosen_dt = presets[int(val) - 1][1]
            chosen = chosen_dt.strftime("%Y%m%d")
            print(f"  → {chosen_dt.strftime('%b %d, %Y')}")
            return chosen
        try:
            dt = datetime.strptime(val, "%Y%m%d")
            print(f"  → {dt.strftime('%b %d, %Y')}")
            return val
        except ValueError:
            print(f"  Invalid. Enter a number 1–{len(presets)} or a date (YYYYMMDD).")


def prompt_time(default=None):
    default_display = default if default and default != "0000" else None
    ans = _readline_or_cancel(
        f"Include a time (HHMM)?{f' current: {default}' if default_display else ''} (y/N): "
    )
    if ans is None:
        return None
    if ans.strip().lower() != "y":
        return default or "0000"

    now = datetime.now()
    presets = [
        ("+1 hour",   now + timedelta(hours=1)),
        ("+2 hours",  now + timedelta(hours=2)),
        ("+4 hours",  now + timedelta(hours=4)),
        ("Morning",   now.replace(hour=9,  minute=0, second=0, microsecond=0)),
        ("Noon",      now.replace(hour=12, minute=0, second=0, microsecond=0)),
        ("Afternoon", now.replace(hour=15, minute=0, second=0, microsecond=0)),
        ("Evening",   now.replace(hour=18, minute=0, second=0, microsecond=0)),
        ("Night",     now.replace(hour=21, minute=0, second=0, microsecond=0)),
    ]

    print("Time:")
    for i, (label, t) in enumerate(presets, 1):
        print(f"  {i})  {label:<12} {t.strftime('%I:%M %p')}")

    if default_display:
        prompt = f"  #, or time (HHMM) [{default}] [esc=cancel]: "
    else:
        prompt = f"  #, or time (HHMM) [esc=cancel]: "

    while True:
        val = _readline_or_cancel(prompt)
        if val is None:
            return None
        val = val.strip()
        if not val:
            if default_display:
                print(f"  → {datetime.strptime(default, '%H%M').strftime('%I:%M %p')}")
                return default
            print(f"  Enter a number 1–{len(presets)} or a time (HHMM).")
            continue
        if val.isdigit() and 1 <= int(val) <= len(presets):
            chosen_t = presets[int(val) - 1][1]
            chosen = chosen_t.strftime("%H%M")
            print(f"  → {chosen_t.strftime('%I:%M %p')}")
            return chosen
        try:
            t = datetime.strptime(val, "%H%M")
            print(f"  → {t.strftime('%I:%M %p')}")
            return val
        except ValueError:
            print(f"  Invalid. Enter a number 1–{len(presets)} or a time (HHMM).")


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_show(cfg):
    reminders = load_reminders(cfg["data_file"])
    hidden = load_hidden(cfg["hidden_file"])
    snoozed = load_snoozed(cfg["snooze_file"])
    now = datetime.now()
    method = cfg.get("notification", "zenity")

    # Clear expired snoozes
    expired = {r for r, exp in snoozed.items()
               if datetime.strptime(exp, "%Y%m%d%H%M") <= now}
    if expired:
        for r in expired:
            del snoozed[r]
        save_snoozed(cfg["snooze_file"], snoozed)

    due = [
        r for r in reminders
        if r[0] not in hidden
        and r[0] not in snoozed
        and datetime.strptime(r[1], "%Y%m%d%H%M") <= now
    ]
    if not due:
        return

    if method == "notify-send":
        text = "\n\n".join(
            f"Reminder #{refno}\nDate: {format_dt(dt_str)}\nTopic: {topic}\n{desc}"
            for refno, dt_str, topic, desc in due
        )
        subprocess.run(
            ["notify-send", "-a", "qremind", "-i", "appointment-soon", "Reminders Due", text],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return

    to_hide, to_delete = set(), set()
    for refno, dt_str, topic, desc in due:
        text = f"Date: {format_dt(dt_str)}\nTopic: {topic}\n{desc}"
        action = _zenity_reminder(refno, text)
        if action == "hide":
            to_hide.add(refno)
        elif action == "delete":
            to_delete.add(refno)
        elif action == "snooze":
            intervals = _parse_snooze_intervals(cfg.get("snooze_intervals", DEFAULT_CONFIG["snooze_intervals"]))
            minutes = _zenity_snooze_picker(intervals)
            if minutes is not None:
                expiry = (now + timedelta(minutes=minutes)).strftime("%Y%m%d%H%M")
                snoozed[refno] = expiry
                save_snoozed(cfg["snooze_file"], snoozed)

    if to_hide:
        save_hidden(cfg["hidden_file"], hidden | to_hide)
    if to_delete:
        remaining = [r for r in reminders if r[0] not in to_delete]
        save_reminders(cfg["data_file"], remaining)
        if hidden & to_delete:
            save_hidden(cfg["hidden_file"], (hidden | to_hide) - to_delete)
        for r in to_delete:
            snoozed.pop(r, None)
        save_snoozed(cfg["snooze_file"], snoozed)


def cmd_list(cfg):
    reminders = load_reminders(cfg["data_file"])
    if not reminders:
        print("No reminders.")
        return

    hidden = load_hidden(cfg["hidden_file"])
    now = datetime.now()

    for refno, dt_str, topic, desc in reminders:
        reminder_time = datetime.strptime(dt_str, "%Y%m%d%H%M")
        status = "Upcoming" if reminder_time > now else "Due"
        tag = " [Hidden]" if refno in hidden else ""
        print(f"#{refno:>3}  {format_dt(dt_str)}  [{status}{tag}]")
        print(f"       Topic: {topic}")
        print(f"       {desc}\n")


def cmd_add(cfg):
    date_str = prompt_date()
    if date_str is None:
        print("Cancelled.")
        return
    time_str = prompt_time()
    if time_str is None:
        print("Cancelled.")
        return
    while True:
        topic = _readline_or_cancel("Topic: ")
        if topic is None:
            print("Cancelled.")
            return
        if topic.strip():
            break
        print("  Topic is required.")
    description = _readline_or_cancel("Description: ")
    if description is None:
        print("Cancelled.")
        return

    reminders = load_reminders(cfg["data_file"])
    refno = next_refno(reminders)
    reminders.append([refno, date_str + time_str, topic.strip(), description.strip()])

    Path(cfg["data_file"]).parent.mkdir(parents=True, exist_ok=True)
    save_reminders(cfg["data_file"], reminders)
    print(f"Reminder #{refno} added.")


def cmd_edit(refno_str, cfg):
    reminders = load_reminders(cfg["data_file"])
    if refno_str is None:
        if not reminders:
            print("No reminders.")
            return
        items = [
            f"#{r[0]:<4} {format_dt(r[1])}  {r[2]}"
            for r in reminders
        ]
        chosen = _pick_from_list("Select reminder to edit (↑↓ to move, Enter to select, ESC to cancel):", items)
        if chosen is None:
            print("Cancelled.")
            return
        refno_str = reminders[chosen][0]

    for i, (refno, dt_str, topic, desc) in enumerate(reminders):
        if refno != refno_str:
            continue
        print(f"Editing #{refno}: {topic}  [{format_dt(dt_str)}]")
        print("(Press Enter to keep the current value)\n")

        date_str = prompt_date(default=dt_str[:8])
        if date_str is None:
            print("Cancelled.")
            return

        time_str = prompt_time(default=dt_str[8:])
        if time_str is None:
            print("Cancelled.")
            return

        new_topic = _readline_or_cancel(f"Topic [{topic}]: ")
        if new_topic is None:
            print("Cancelled.")
            return
        new_topic = new_topic.strip() or topic

        new_desc = _readline_or_cancel(f"Description [{desc}]: ")
        if new_desc is None:
            print("Cancelled.")
            return
        new_desc = new_desc.strip() or desc

        reminders[i] = [refno, date_str + time_str, new_topic, new_desc]
        save_reminders(cfg["data_file"], reminders)
        print(f"Reminder #{refno} updated.")
        return
    print(f"Reminder #{refno_str} not found.")


def cmd_hide(refno_arg, cfg):
    if refno_arg is None:
        reminders = load_reminders(cfg["data_file"])
        hidden = load_hidden(cfg["hidden_file"])
        candidates = [r for r in reminders if r[0] not in hidden]
        if not candidates:
            print("No reminders available to hide.")
            return
        items = [f"#{r[0]:<4} {format_dt(r[1])}  {r[2]}" for r in candidates]
        chosen = _pick_multi_from_list("Select reminders to hide:", items)
        if chosen is None or not chosen:
            print("Cancelled." if chosen is None else "Nothing selected.")
            return
        refno_arg = ",".join(candidates[i][0] for i in chosen)

    targets = {r.strip() for r in refno_arg.split(",")}
    existing = {r[0] for r in load_reminders(cfg["data_file"])}
    not_found = sorted(targets - existing, key=lambda x: int(x) if x.isdigit() else 0)
    to_hide = targets & existing
    for n in not_found:
        print(f"Reminder #{n} not found.")
    if not to_hide:
        return
    hidden = load_hidden(cfg["hidden_file"])
    hidden |= to_hide
    save_hidden(cfg["hidden_file"], hidden)
    for n in sorted(to_hide, key=lambda x: int(x) if x.isdigit() else 0):
        print(f"Reminder #{n} hidden (won't appear in notifications).")


def cmd_unhide(refno_arg, cfg):
    if refno_arg is None:
        reminders = load_reminders(cfg["data_file"])
        hidden = load_hidden(cfg["hidden_file"])
        candidates = [r for r in reminders if r[0] in hidden]
        if not candidates:
            print("No hidden reminders.")
            return
        items = [f"#{r[0]:<4} {format_dt(r[1])}  {r[2]}" for r in candidates]
        chosen = _pick_multi_from_list("Select reminders to unhide:", items)
        if chosen is None or not chosen:
            print("Cancelled." if chosen is None else "Nothing selected.")
            return
        refno_arg = ",".join(candidates[i][0] for i in chosen)

    targets = {r.strip() for r in refno_arg.split(",")}
    hidden = load_hidden(cfg["hidden_file"])
    not_hidden = sorted(targets - hidden, key=lambda x: int(x) if x.isdigit() else 0)
    to_unhide = targets & hidden
    for n in not_hidden:
        print(f"Reminder #{n} is not hidden.")
    if not to_unhide:
        return
    save_hidden(cfg["hidden_file"], hidden - to_unhide)
    for n in sorted(to_unhide, key=lambda x: int(x) if x.isdigit() else 0):
        print(f"Reminder #{n} unhidden.")


def cmd_delete(refno_arg, cfg):
    if refno_arg is None:
        reminders = load_reminders(cfg["data_file"])
        if not reminders:
            print("No reminders.")
            return
        items = [f"#{r[0]:<4} {format_dt(r[1])}  {r[2]}" for r in reminders]
        chosen = _pick_multi_from_list("Select reminders to delete:", items)
        if chosen is None or not chosen:
            print("Cancelled." if chosen is None else "Nothing selected.")
            return
        refno_arg = ",".join(reminders[i][0] for i in chosen)

    targets = {r.strip() for r in refno_arg.split(",")}
    reminders = load_reminders(cfg["data_file"])
    existing = {r[0] for r in reminders}
    not_found = sorted(targets - existing, key=lambda x: int(x) if x.isdigit() else 0)
    to_delete = targets & existing
    if not_found:
        for n in not_found:
            print(f"Reminder #{n} not found.")
    if not to_delete:
        return
    save_reminders(cfg["data_file"], [r for r in reminders if r[0] not in to_delete])
    hidden = load_hidden(cfg["hidden_file"])
    if hidden & to_delete:
        save_hidden(cfg["hidden_file"], hidden - to_delete)
    for n in sorted(to_delete, key=lambda x: int(x) if x.isdigit() else 0):
        print(f"Reminder #{n} deleted.")


def cmd_snooze(cfg):
    snoozed = load_snoozed(cfg["snooze_file"])
    now = datetime.now()

    # Clear expired snoozes
    expired = {r for r, exp in snoozed.items()
               if datetime.strptime(exp, "%Y%m%d%H%M") <= now}
    if expired:
        for r in expired:
            del snoozed[r]
        save_snoozed(cfg["snooze_file"], snoozed)

    hidden = load_hidden(cfg["hidden_file"])
    reminders = load_reminders(cfg["data_file"])
    candidates = [
        r for r in reminders
        if r[0] not in hidden
        and datetime.strptime(r[1], "%Y%m%d%H%M") <= now
    ]

    if not candidates:
        print("No due reminders.")
        return

    toggled = _pick_snooze_list(candidates, snoozed)
    if toggled is None:
        print("Cancelled.")
        return
    if not toggled:
        print("No changes.")
        return

    intervals = _parse_snooze_intervals(cfg.get("snooze_intervals", DEFAULT_CONFIG["snooze_intervals"]))
    changed = 0
    for i in toggled:
        refno, _, topic, _ = candidates[i]
        if refno in snoozed:
            del snoozed[refno]
            print(f"Snooze cancelled for #{refno} ({topic}).")
            changed += 1
        else:
            chosen = _pick_from_list(
                f"Snooze #{refno} ({topic}) for how long?",
                [label for label, _ in intervals],
            )
            if chosen is not None:
                minutes = intervals[chosen][1]
                expiry = (now + timedelta(minutes=minutes)).strftime("%Y%m%d%H%M")
                snoozed[refno] = expiry
                print(f"#{refno} ({topic}) snoozed for {intervals[chosen][0]}.")
                changed += 1

    if changed:
        save_snoozed(cfg["snooze_file"], snoozed)


def cmd_clean(cfg):
    reminders = load_reminders(cfg["data_file"])
    hidden = load_hidden(cfg["hidden_file"])
    remaining = [r for r in reminders if r[0] not in hidden]
    removed = len(reminders) - len(remaining)
    renumbered = [[str(i + 1)] + r[1:] for i, r in enumerate(remaining)]
    save_reminders(cfg["data_file"], renumbered)
    try:
        Path(cfg["hidden_file"]).unlink()
    except FileNotFoundError:
        pass
    print(f"Removed {removed} hidden reminder(s). Remaining reminders renumbered.")


def cmd_config(keys_vals, cfg):
    if not keys_vals:
        print(json.dumps(cfg, indent=2))
        return
    for kv in keys_vals:
        if "=" not in kv:
            print(f"Error: expected key=value, got: {kv}")
            return
        key, val = kv.split("=", 1)
        if key not in DEFAULT_CONFIG:
            print(f"Unknown config key: {key}")
            print(f"Valid keys: {', '.join(DEFAULT_CONFIG)}")
            return
        if key == "check_interval_minutes":
            try:
                val = int(val)
            except ValueError:
                print("check_interval_minutes must be an integer.")
                return
        cfg[key] = val
    save_config(cfg)
    print("Config saved.")
    if any(kv.startswith("check_interval_minutes=") for kv in keys_vals):
        timer = Path.home() / ".config/systemd/user/qreminder.timer"
        if timer.exists():
            print("Note: systemd timer is installed — re-run --install to apply the new interval.")


def cmd_status(cfg):
    print(f"Config: {CONFIG_FILE}")
    print(json.dumps(cfg, indent=2))
    print()

    timer = Path.home() / ".config/systemd/user/qreminder.timer"
    if timer.exists():
        result = subprocess.run(
            ["systemctl", "--user", "status", "qreminder.timer"],
            capture_output=True, text=True,
        )
        print("Systemd timer status:")
        print(result.stdout or result.stderr)
    elif PID_FILE.exists():
        pid = PID_FILE.read_text().strip()
        try:
            os.kill(int(pid), 0)
            print(f"Daemon running (PID {pid}).")
        except (ProcessLookupError, ValueError):
            print("Daemon PID file exists but process is not running (stale).")
    else:
        print("No timer or daemon active. Run --install or --daemon to enable periodic checks.")


# ── Daemon ────────────────────────────────────────────────────────────────────

def cmd_daemon(cfg):
    interval_sec = cfg.get("check_interval_minutes", 60) * 60

    def handle_signal(sig, _frame):
        if PID_FILE.exists():
            PID_FILE.unlink()
        sys.exit(0)

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(str(os.getpid()))

    try:
        print(
            f"qremind daemon started (PID {os.getpid()}, "
            f"checking every {cfg['check_interval_minutes']} minute(s))"
        )
        while True:
            cmd_show(cfg)
            time.sleep(interval_sec)
    finally:
        if PID_FILE.exists():
            PID_FILE.unlink()


def cmd_stop(_cfg):
    if not PID_FILE.exists():
        print("No daemon PID file found.")
        return
    pid_str = PID_FILE.read_text().strip()
    try:
        os.kill(int(pid_str), signal.SIGTERM)
        print(f"Daemon (PID {pid_str}) stopped.")
    except ProcessLookupError:
        print("Daemon not running (removing stale PID file).")
        PID_FILE.unlink()


# ── Install / uninstall ───────────────────────────────────────────────────────

def cmd_install_systemd(cfg):
    script_path = Path(sys.argv[0]).resolve()
    interval = cfg.get("check_interval_minutes", 60)

    systemd_dir = Path.home() / ".config/systemd/user"
    systemd_dir.mkdir(parents=True, exist_ok=True)

    (systemd_dir / "qreminder.service").write_text(
        "[Unit]\nDescription=qremind notification check\n\n"
        f"[Service]\nType=oneshot\nExecStart={script_path} --show\n"
    )
    (systemd_dir / "qreminder.timer").write_text(
        f"[Unit]\nDescription=qremind - check every {interval} minute(s)\n\n"
        f"[Timer]\nOnBootSec=1min\nOnUnitActiveSec={interval}min\n\n"
        "[Install]\nWantedBy=timers.target\n"
    )

    subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
    subprocess.run(["systemctl", "--user", "enable", "--now", "qreminder.timer"], check=True)
    print(f"Systemd user timer installed (every {interval} minutes).")
    print("Check status:    systemctl --user status qreminder.timer")
    print("View next fire:  systemctl --user list-timers qreminder.timer")


def cmd_install_autostart(cfg):
    script_path = Path(sys.argv[0]).resolve()
    autostart_dir = Path.home() / ".config/autostart"
    autostart_dir.mkdir(parents=True, exist_ok=True)
    desktop = autostart_dir / "qreminder.desktop"
    desktop.write_text(
        "[Desktop Entry]\nType=Application\nName=qremind\n"
        f"Exec={script_path} --daemon\n"
        "X-GNOME-Autostart-enabled=true\nNoDisplay=true\n"
        "Comment=qremind periodic reminder daemon\n"
    )
    print(f"GNOME autostart entry installed: {desktop}")
    print(f"Daemon will check every {cfg.get('check_interval_minutes', 60)} minute(s) after login.")


def cmd_uninstall():
    removed = []

    service = Path.home() / ".config/systemd/user/qreminder.service"
    timer = Path.home() / ".config/systemd/user/qreminder.timer"
    if timer.exists() or service.exists():
        subprocess.run(
            ["systemctl", "--user", "disable", "--now", "qreminder.timer"],
            capture_output=True,
        )
        for f in (service, timer):
            if f.exists():
                f.unlink()
                removed.append(str(f))
        subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)

    autostart = Path.home() / ".config/autostart/qreminder.desktop"
    if autostart.exists():
        autostart.unlink()
        removed.append(str(autostart))

    if removed:
        print("Removed:\n  " + "\n  ".join(removed))
    else:
        print("Nothing to uninstall.")


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="qremind",
        description="Desktop reminder app with configurable periodic checking.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  qremind --add                               Add a new reminder interactively
  qremind --list                              List all reminders with status
  qremind --edit                              Select a reminder to edit interactively
  qremind --edit 2                            Edit reminder #2 directly
  qremind --hide 3                            Suppress reminder #3 from notifications
  qremind --hide 3,7,12                       Suppress multiple reminders
  qremind --unhide 3                          Restore reminder #3 to notifications
  qremind --unhide 3,7,12                     Restore multiple reminders
  qremind --delete 3                          Permanently delete reminder #3
  qremind --delete 1,4,6,10                  Permanently delete multiple reminders
  qremind --snooze                            Manage snoozes for due reminders
  qremind --clean                             Remove hidden reminders and renumber
  qremind --config                                      Show current config
  qremind --config check_interval_minutes=30            Set check interval to 30 minutes
  qremind --config notification=notify-send             Switch to desktop notification style
  qremind --config snooze_intervals=30m,1h,2h,3h,6h    Set snooze duration options
  qremind --install                           Install systemd user timer (recommended)
  qremind --install-autostart                 Install GNOME autostart (daemon mode)
  qremind --uninstall                         Remove timer and/or autostart entry
  qremind --status                            Show timer/daemon status
""",
    )

    parser.add_argument("--show", action="store_true",
                        help="Check and display due reminders (called by timer/daemon)")
    parser.add_argument("--list", action="store_true",
                        help="List all reminders")
    parser.add_argument("--add", action="store_true",
                        help="Add a new reminder interactively")
    parser.add_argument("--edit", metavar="N", nargs="?", const="",
                        help="Edit reminder #N (omit N to select interactively)")
    parser.add_argument("--hide", metavar="N[,N...]", nargs="?", const="",
                        help="Suppress reminder(s) from notifications (omit N to select interactively)")
    parser.add_argument("--unhide", metavar="N[,N...]", nargs="?", const="",
                        help="Restore suppressed reminder(s) (omit N to select interactively)")
    parser.add_argument("--delete", metavar="N[,N...]", nargs="?", const="",
                        help="Permanently delete reminder(s) (omit N to select interactively)")
    parser.add_argument("--snooze", action="store_true",
                        help="View and cancel active snoozes")
    parser.add_argument("--clean", action="store_true",
                        help="Remove hidden reminders and renumber")
    parser.add_argument("--daemon", action="store_true",
                        help="Run as background daemon (checks at configured interval)")
    parser.add_argument("--stop", action="store_true",
                        help="Stop the running daemon")
    parser.add_argument("--install", action="store_true",
                        help="Install systemd user timer (persists across reboots)")
    parser.add_argument("--install-autostart", action="store_true", dest="install_autostart",
                        help="Install GNOME autostart entry (daemon mode)")
    parser.add_argument("--uninstall", action="store_true",
                        help="Remove systemd timer and/or autostart entry")
    parser.add_argument("--status", action="store_true",
                        help="Show config and timer/daemon status")
    parser.add_argument("--config", nargs="*", metavar="key=value",
                        help="Show config (no args) or set key=value pairs")

    args = parser.parse_args()
    cfg = load_config()

    if args.show:
        cmd_show(cfg)
    elif args.list:
        cmd_list(cfg)
    elif args.add:
        cmd_add(cfg)
    elif args.edit is not None:
        cmd_edit(args.edit or None, cfg)
    elif args.hide is not None:
        cmd_hide(args.hide or None, cfg)
    elif args.unhide is not None:
        cmd_unhide(args.unhide or None, cfg)
    elif args.delete is not None:
        cmd_delete(args.delete or None, cfg)
    elif args.snooze:
        cmd_snooze(cfg)
    elif args.clean:
        cmd_clean(cfg)
    elif args.daemon:
        cmd_daemon(cfg)
    elif args.stop:
        cmd_stop(cfg)
    elif args.install:
        cmd_install_systemd(cfg)
    elif args.install_autostart:
        cmd_install_autostart(cfg)
    elif args.uninstall:
        cmd_uninstall()
    elif args.status:
        cmd_status(cfg)
    elif args.config is not None:
        cmd_config(args.config, cfg)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
